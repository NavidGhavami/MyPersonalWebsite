@{
    ViewData["Title"] = "نمونه کارهای من";
}

<div class="row card-container">

    <!--
    Card Wrap
    -->
    <div class="card-wrap col col-m-12 col-t-12 col-d-8 col-d-lg-6" data-simplebar>

        <!-- Work Image -->
        <div class="card-image col col-m-12 col-t-12 col-d-4 col-d-lg-6">
            <img class="full-max-width" src="~/images/Navid3.jpg" />
        </div>

        <!--
        Inner Top
        -->
        <div class="content inner-top">
            <div class="row">
                <div class="col col-m-12 col-t-12 col-d-12 col-d-lg-12">
                    <div class="title-bg">نمونه کار</div>
                </div>
            </div>
        </div>

        <!--
        Works
        -->
        <div class="content works">
            <div class="row">
                <div class="col col-m-12 col-t-5 col-d-5 col-d-lg-5">

                    <!-- title -->
                    <div class="title"><span>نمونه </span>کارهای من</div>

                </div>
                <div class="col col-m-12 col-t-7 col-d-7 col-d-lg-7">

                    <!-- filters -->
                    <div class="filter-menu filter-button-group">
                        <div class="f_btn active">
                            <label>
                                <input type="radio" name="fl_radio" value="grid-item" />
                                همه
                            </label>
                        </div>
                        <div class="f_btn">
                            <label>
                                <input type="radio" name="fl_radio" value="photo" />
                                فروشگاهی
                            </label>
                        </div>
                        <div class="f_btn">
                            <label>
                                <input type="radio" name="fl_radio" value="photo" />
                                خبری
                            </label>
                        </div>
                        <div class="f_btn">
                            <label>
                                <input type="radio" name="fl_radio" value="photo" />
                                شرکتی
                            </label>
                        </div>
                    </div>

                </div>
            </div>

            @await Component.InvokeAsync("Project")

        </div>
    </div>
</div>