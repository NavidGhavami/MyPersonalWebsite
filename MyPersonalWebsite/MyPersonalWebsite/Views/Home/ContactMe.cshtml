@model ContactMe.ContactForm
@{
    ViewData["Title"] = "تماس با من";
}

    <div class="row card-container">

        <!--
        Card Wrap
        -->
        <div class="card-wrap col col-m-12 col-t-12 col-d-8 col-d-lg-6" data-simplebar>

            <!-- Map -->
            <div class="card-image col col-m-12 col-t-12 col-d-4 col-d-lg-6">
                <div class="map" id="map"></div>
            </div>

            <!--
            Inner Top
            -->
            <div class="content inner-top">
                <div class="row">
                    <div class="col col-m-12 col-t-12 col-d-12 col-d-lg-12">
                        <div class="title-bg">تماس بامن</div>
                    </div>
                </div>
            </div>

            @await Component.InvokeAsync("ContactMe")

            <!--
            Contacts Form
            -->
            <div class="content contacts-form">
                <div class="row">
                    <div class="col col-m-12 col-t-12 col-d-12 col-d-lg-12">
                        @if (!string.IsNullOrEmpty(ViewBag.success))
                        {
                            <div class="alert-danger">
                                <p>
                                    @ViewBag.success
                                </p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(ViewBag.error))
                        {
                            <div class="alert-danger">
                                <p>
                                    @ViewBag.error
                                </p>
                            </div>
                        }

                        
                        <!-- title -->
                        <div class="title"><span>تماس</span> بامن</div>

                    </div>
                </div>
                <div class="row">
                    <div class="col col-m-12 col-t-12 col-d-12 col-d-lg-12">

                        <!-- form -->
                        <div class="contact_form card-box">
                            <form id="cform" method="post" asp-controller="Home" asp-action="ContactMe">
                                <div class="row">
                                    <div class="col col-m-12 col-t-6 col-d-6 col-d-lg-6">
                                        <div class="group-val">
                                            <input type="text" asp- asp-for="FullName" placeholder="نام و نام خانوادگی"/>
                                            <span asp-validation-for="FullName" class="error"></span>
                                        </div>
                                    </div>
                                    <div class="col col-m-12 col-t-6 col-d-6 col-d-lg-6">
                                        <div class="group-val">
                                            <input type="text" asp-for="Email" placeholder="پست الکترونیکی"/>
                                            <span asp-validation-for="Email" class="error"></span>
                                        </div>
                                    </div>
                                    <div class="col col-m-12 col-t-12 col-d-12 col-d-lg-12">
                                        <div class="group-val">
                                            <textarea asp-for="Message" placeholder="متن پیام"></textarea>
                                            <span asp-validation-for="Message" class="error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="align-left">
                                    <a href="#" class="button" onclick="$('#cform').submit();return false;">
                                        <span class="text">ارسال پیام </span>
                                        <span class="icon">
                                            <i class="la la-arrow-left"></i>
                                        </span>
                                    </a>
                                </div>
                            </form>
                        
                        </div>

                    </div>
                </div>
            </div>

        </div>

    </div>

